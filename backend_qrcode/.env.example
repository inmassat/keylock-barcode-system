# Copy this file to `.env` and fill in real values. Do NOT commit `.env`.

# Database engine: "sqlite" (no external service) or "postgres".
DB_ENGINE=sqlite

# PostgreSQL (only used when DB_ENGINE=postgres).
POSTGRES_DB=barcode
POSTGRES_USER=barcode
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Realtime channel layer: leave unset for the in-memory backend (dev).
# To use Redis, set CHANNEL_BACKEND=redis and REDIS_HOST/REDIS_PORT.
# CHANNEL_BACKEND=redis
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379

# Django
SECRET_KEY=change-me-to-a-long-random-secret
DEBUG=True
ALLOWED_HOSTS=*
